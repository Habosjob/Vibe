base_url: "https://iss.moex.com/iss/engines/stock/markets/bonds/securities.json"
timeout_seconds: 20
request_delay_seconds: 0.15
amortization_request_delay_seconds: 0.02
retries: 3
page_size: 100
output_file: "output/moex_bonds.xlsx"
emitents_output_file: "output/emitents.xlsx"
raw_dump_enabled: false
raw_ttl_hours: 24
raw_max_size_mb: 50

exclusions_state_dir: "state"
exclusion_window_days: 365
qualified_investor_exclusion_days: 30
amortization_workers: 8
dohod_workers: 12
dohod_request_delay_seconds: 0.03
dohod_checkpoint_save_every: 25
cbr_key_rate_url: "https://www.cbr.ru/hd_base/KeyRate/"
cbr_ruonia_url: "https://www.cbr.ru/hd_base/ruonia/"
z_curve_cbr_url: "https://www.cbr.ru/hd_base/zcyc_params/"
z_curve_moex_url: "https://iss.moex.com/iss/engines/stock/zcyc/securities.json?iss.meta=off"
cbr_key_rate_timeout_seconds: 10

storage_backend: "sqlite"
sqlite_db_path: "screener_state.db"
force_cache_refresh: false

# Прогнозная YTM для флоатеров
floater_cb_rate_current_year: 14.0
floater_cb_rate_next_year: 8.5
floater_cb_rate_plus_one_year: 8.0

# Прогнозная инфляция для ОФЗ-ИН (серия 52002/52003/52004/52005)
linker_inflation_current_year: 5.0
linker_inflation_next_year: 4.0
linker_inflation_plus_one_year: 4.0

floater_ruonia_spread_from_cb_rate: -0.5
floater_z_curve_spread_from_cb_rate: -1.0
floater_cbr_rate_spread_from_cb_rate: 0.0
